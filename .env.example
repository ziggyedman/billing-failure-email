# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address. Must be on a domain you've verified in Resend.
# Example: billing@baard.cc
FROM_EMAIL=billing@baard.cc

# The public URL of this app once deployed (used in email links).
# Example: https://billing-failure-email.onrender.com
APP_URL=http://localhost:3000
